# Supabase local (démarré via `pnpm --filter @app/db db:start`).
# Récupère l'URL et la clé anon/publishable avec `supabase status` puis copie ce
# fichier en `.env.local` (gitignoré).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54521
NEXT_PUBLIC_SUPABASE_ANON_KEY=

